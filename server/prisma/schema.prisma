generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, uuidOssp(map: "uuid-ossp"), btree_gist]
}

model User {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String         @db.VarChar(100)
  email         String         @unique @db.VarChar(255)
  password_hash String         @db.VarChar(255)
  role          String         @db.VarChar(20)
  status        String         @default("active") @db.VarChar(20)
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  updated_at    DateTime?      @default(now()) @db.Timestamp(6)
  bookings      Booking[]
  notifications Notification[]
  audit_logs    AuditLog[]

  @@map("users")
}

model Resource {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String      @unique @db.VarChar(100)
  type        String      @db.VarChar(30)
  capacity    Int?        @default(0)
  location    String?     @db.VarChar(200)
  status      String?     @default("available") @db.VarChar(20)
  image_url   String?
  description String?
  created_at  DateTime?   @default(now()) @db.Timestamp(6)
  updated_at  DateTime?   @default(now()) @db.Timestamp(6)
  bookings    Booking[]
  embedding   Embedding?

  @@map("resources")
}

model Booking {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id       String    @db.Uuid
  resource_id   String    @db.Uuid
  start_time    DateTime  @db.Timestamp(6)
  end_time      DateTime  @db.Timestamp(6)
  meeting_title String    @db.VarChar(100)
  description   String?
  participants  Json?     @default("[]")
  status        String?   @default("pending") @db.VarChar(20)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resource_id], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model Embedding {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  resource_id      String    @unique @db.Uuid
  content          String
  embedding_vector Unsupported("vector(1536)")?
  metadata         Json?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)

  resource Resource @relation(fields: [resource_id], references: [id], onDelete: Cascade)

  @@map("embeddings")
}

model Notification {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @db.Uuid
  type       String    @db.VarChar(30)
  title      String    @db.VarChar(100)
  message    String
  link       String?   @db.VarChar(255)
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String?   @db.Uuid
  action      String    @db.VarChar(30)
  entity_type String    @db.VarChar(30)
  entity_id   String?   @db.Uuid
  details     Json?
  ip_address  String?   @db.VarChar(45)
  user_agent  String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
